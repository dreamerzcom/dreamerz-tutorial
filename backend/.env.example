# ── Database ──────────────────────────────────────────
# Defaults to a local SQLite file if unset. For production use Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host/db
# DATABASE_URL=sqlite+aiosqlite:///./dreamerz.db

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Anthropic (Claude) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudinary (media uploads) ────────────────────────
# Full format includes the cloud name after '@':
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# Find it in your Cloudinary dashboard → Programmable Media → API Keys
# (labelled "API environment variable"). If unset, image/video uploads
# fall back to writing under ./uploads — fine for local dev only.
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name
